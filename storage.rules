// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // CV files:
    // - Anyone can READ (public download links)
    // - Only authenticated admins can UPLOAD
    match /cvs/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType.matches('application/(pdf|msword|vnd.openxmlformats-officedocument.wordprocessingml.document)');
    }

  }
}
